<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="SecureArchive.Views.PairingQrDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Pairing QR"
    CloseButtonText="Close">
    <Grid Width="480" RowSpacing="8" Padding="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap"
                   Text="Scan this QR with BooDroid (or any QR scanner) to register this server. The fingerprint embedded in the QR is used to verify the server, so install only from a trusted display."/>

        <Border Grid.Row="1" Background="White" Padding="10" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Image x:Name="QrImage" Stretch="Uniform" MaxHeight="320" MaxWidth="320"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,0">
            <TextBlock Text="Host:" VerticalAlignment="Center"/>
            <ComboBox x:Name="HostCombo" MinWidth="240" SelectionChanged="OnHostChanged"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="URI:" Margin="0,8,0,0"/>
        <TextBox Grid.Row="4" x:Name="UriBox" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"/>

        <TextBlock Grid.Row="5" x:Name="HintText" Foreground="Gray" TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"/>
    </Grid>
</ContentDialog>

<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SecureArchive.Views.SyncArchiveDialogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SecureArchive.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="400"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Page.Resources>
        <ResourceDictionary Source="./Converters.xaml"/>
    </Page.Resources>

    <Grid Padding="8">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="10">
            <Grid HorizontalAlignment="Stretch">
                <TextBlock Text="Peer Address" VerticalAlignment="Bottom"/>
                <Button HorizontalAlignment="Right" Padding="0" Width="46" Height="32" Command="{x:Bind ViewModel.DiscoverCommand}" ToolTipService.ToolTip="Discover Peer">
                    <PathIcon Data="M 21.86 12.5C 21.1 11.63 20.15 11.13 19 11 19 9.05 18.32 7.4 16.96 6.04 15.6 4.68 13.95 4 12 4 10.42 4 9 4.47 7.75 5.43S 5.67 7.62 5.25 9.15C 4 9.43 2.96 10.08 2.17 11.1S 1 13.28 1 14.58C 1 16.09 1.54 17.38 2.61 18.43 3.69 19.5 5 20 6.5 20H 18.5C 19.75 20 20.81 19.56 21.69 18.69 22.56 17.81 23 16.75 23 15.5 23 14.35 22.62 13.35 21.86 12.5M 20.27 17.27C 19.79 17.76 19.2 18 18.5 18H 6.5C 5.53 18 4.71 17.66 4.03 17 3.34 16.29 3 15.47 3 14.5S 3.34 12.71 4.03 12.03C 4.71 11.34 5.53 11 6.5 11H 7C 7 9.62 7.5 8.44 8.46 7.46 9.44 6.5 10.62 6 12 6S 14.56 6.5 15.54 7.46C 16.5 8.44 17 9.62 17 11V 13H 18.5C 19.2 13 19.79 13.24 20.27 13.73S 21 14.8 21 15.5 20.76 16.79 20.27 17.27M 16 12C 16 9.79 14.21 8 12 8S 8 9.79 8 12 9.79 16 12 16C 12.74 16 13.43 15.79 14 15.43L 16.57 18 18 16.57 15.43 14C 15.79 13.43 16 12.74 16 12M 12 14C 10.9 14 10 13.11 10 12S 10.9 10 12 10 14 10.9 14 12 13.11 14 12 14Z"/>
                </Button>
            </Grid>
            <TextBox Text="{x:Bind ViewModel.PeerAddress.Value, Mode=TwoWay}"/>
            <CheckBox Content="Use HTTPS" IsChecked="{x:Bind ViewModel.IsHttps.Value, Mode=TwoWay}"/>
            <TextBlock Text="Peer Password"/>
            <PasswordBox Password="{x:Bind ViewModel.Password.Value, Mode=TwoWay}"/>
            <CheckBox Content="Peer to Local Only" IsChecked="{x:Bind ViewModel.PeerToLocalOnly.Value, Mode=TwoWay}"/>
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage.Value, Mode=OneWay}"/>

            <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.Running.Value, Converter={StaticResource NegBoolVisibilityConverter}, Mode=OneWay}">
                <Button Width="120" Content="Start" Command="{x:Bind ViewModel.StartCommand}"/>
                <Button Width="120" Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}"/>
            </StackPanel>

            <StackPanel x:Name="ProgressPanel" Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="10" Visibility="{x:Bind ViewModel.Running.Value, Converter={StaticResource BoolVisibilityConverter}, Mode=OneWay}">
                <TextBlock x:Name="MessageText" Text="{x:Bind ViewModel.ProgressMessage.Value, Mode=OneWay}"/>
                <ProgressBar x:Name="CountProgressBar" Maximum="100" Minimum="0" Value="{x:Bind ViewModel.CountProgress.Value, Mode=OneWay}"/>
                <TextBlock HorizontalAlignment="Center">
                    <Run Text="{x:Bind ViewModel.CurrentIndex.Value, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{x:Bind ViewModel.TotalCount.Value, Mode=OneWay}"/>
                </TextBlock>
                <ProgressBar x:Name="SizeProgressBar" Maximum="100" Minimum="0" Value="{x:Bind ViewModel.SizeProgress.Value, Mode=OneWay}"/>
                <TextBlock HorizontalAlignment="Center">
                    <Run Text="{x:Bind ViewModel.CurrentBytes.Value, Converter={StaticResource SizeStringConverter}, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{x:Bind ViewModel.TotalLength.Value, Converter={StaticResource SizeStringConverter}, Mode=OneWay}"/>
                </TextBlock>

                <Button Width="120" Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
        <Grid
            Visibility="{x:Bind ViewModel.Discovering.Value, Converter={StaticResource BoolVisibilityConverter}, Mode=OneWay}"
            Background="#5000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="20" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ListBox 
                Grid.Row="0"
                ItemsSource="{x:Bind ViewModel.DiscoveringModel.DiscoveredPeers}"
                SelectedItem="{x:Bind ViewModel.DiscoveringModel.SelectedPeer.Value, Mode=TwoWay}"
                DisplayMemberPath="DisplayLabel"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>
            <TextBlock Grid.Row="0" Text="Not Found" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{x:Bind ViewModel.DiscoveringModel.NoPeer.Value, Converter={StaticResource BoolVisibilityConverter}, Mode=OneWay}"/>
            <Button Grid.Row="1" Content="×" Command="{x:Bind ViewModel.DiscoveringModel.CancelDiscoveringCommand}" HorizontalAlignment="Center"/>
        </Grid>

    </Grid>
</Page>
